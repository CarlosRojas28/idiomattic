{
  "name": "idiomatticwp/idiomattic-wp",
  "description": "The fastest multilingual WordPress plugin. BYOK AI translation — connect OpenAI, Claude, DeepL or Google directly.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "version": "1.0.0",
  "authors": [
    {
      "name": "Idiomattic WP",
      "homepage": "https://idiomatticwp.com"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "brain/monkey": "^2.6",
    "wp-phpunit/wp-phpunit": "^6.4",
    "phpstan/phpstan": "^1.10",
    "phpstan/phpstan-phpunit": "^1.3",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "squizlabs/php_codesniffer": "^3.8",
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "IdiomatticWP\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IdiomatticWP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test":        "phpunit --testdox",
    "test:unit":   "phpunit --testdox --testsuite=unit",
    "test:int":    "phpunit --testdox --testsuite=integration",
    "analyse":     "phpstan analyse includes --level=6",
    "cs":          "phpcs --standard=WordPress includes",
    "cs-fix":      "phpcbf --standard=WordPress includes",
    "check":       [
      "@cs",
      "@analyse",
      "@test:unit"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "extra": {
    "installer-paths": {
      "vendor/{$vendor}/{$name}/": ["type:wordpress-plugin"]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
